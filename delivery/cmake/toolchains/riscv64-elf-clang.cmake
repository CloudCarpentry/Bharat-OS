set(CMAKE_SYSTEM_NAME Generic)
set(CMAKE_SYSTEM_PROCESSOR riscv64)

set(CMAKE_C_COMPILER clang)
set(CMAKE_CXX_COMPILER clang++)
set(CMAKE_ASM_COMPILER clang)
set(CMAKE_C_COMPILER_TARGET riscv64-unknown-none-elf)
set(CMAKE_CXX_COMPILER_TARGET riscv64-unknown-none-elf)
set(CMAKE_ASM_COMPILER_TARGET riscv64-unknown-none-elf)

find_program(BHARAT_RISCV_LLVM_OBJCOPY NAMES llvm-objcopy-20 llvm-objcopy-19 llvm-objcopy-18 llvm-objcopy-17 llvm-objcopy)
if(BHARAT_RISCV_LLVM_OBJCOPY MATCHES "/\\.swiftly/")
    unset(BHARAT_RISCV_LLVM_OBJCOPY CACHE)
endif()
find_program(BHARAT_RISCV_GNU_OBJCOPY NAMES riscv64-unknown-elf-objcopy)
find_program(BHARAT_GENERIC_OBJCOPY NAMES objcopy)
if(BHARAT_RISCV_LLVM_OBJCOPY)
    set(CMAKE_OBJCOPY "${BHARAT_RISCV_LLVM_OBJCOPY}")
elseif(BHARAT_RISCV_GNU_OBJCOPY)
    set(CMAKE_OBJCOPY "${BHARAT_RISCV_GNU_OBJCOPY}")
elseif(BHARAT_GENERIC_OBJCOPY)
    set(CMAKE_OBJCOPY "${BHARAT_GENERIC_OBJCOPY}")
endif()

set(CMAKE_TRY_COMPILE_TARGET_TYPE STATIC_LIBRARY)

set(CMAKE_C_COMPILER_WORKS 1)
set(CMAKE_CXX_COMPILER_WORKS 1)
