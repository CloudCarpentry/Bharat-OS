{
  "boards": {
    "qemu-virt-x86_64": {
      "arch": "x86_64",
      "machine": "virt",
      "cpu": "host",
      "qemu_system": "qemu-system-x86_64",
      "default_toolchain": "gcc",
      "toolchains": {
        "gcc": "cmake/toolchains/x86_64-gcc.cmake",
        "llvm": "cmake/toolchains/x86_64-llvm.cmake"
      },
      "hardware_profile": "EDGE",
      "tier": "LINUX_LIKE",
      "boot_hw": "virt",
      "payload_format": "kernel-elf",
      "flash_script_dir": "tools/boards/qemu-virt-x86_64",
      "supports_flash": false,
      "memory_mb": 256,
      "smp": 4
    },
    "qemu-virt-arm64": {
