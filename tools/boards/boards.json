        "llvm": "cmake/toolchains/arm64-llvm.cmake"
      },
      "hardware_profile": "EDGE",
      "tier": "LINUX_LIKE",
      "boot_hw": "virt",
      "payload_format": "kernel-elf",
      "flash_script_dir": "tools/boards/qemu-virt-arm64",
      "supports_flash": false,
      "memory_mb": 256,
      "smp": 4
    },
    "qemu-virt-riscv64": {
