/*
 * Canonical Bharat syscall number table.
 * ABI rule: never renumber/reorder existing entries; append only.
 */
SYSCALL_DEF(SYSCALL_NOP, 0)
SYSCALL_DEF(SYSCALL_THREAD_CREATE, 1)
SYSCALL_DEF(SYSCALL_THREAD_DESTROY, 2)
SYSCALL_DEF(SYSCALL_SCHED_YIELD, 3)
SYSCALL_DEF(SYSCALL_VMM_MAP_PAGE, 4)
SYSCALL_DEF(SYSCALL_VMM_UNMAP_PAGE, 5)
SYSCALL_DEF(SYSCALL_CAPABILITY_INVOKE, 6)
SYSCALL_DEF(SYSCALL_ENDPOINT_CREATE, 7)
SYSCALL_DEF(SYSCALL_ENDPOINT_SEND, 8)
SYSCALL_DEF(SYSCALL_ENDPOINT_RECEIVE, 9)
SYSCALL_DEF(SYSCALL_CAPABILITY_DELEGATE, 10)
SYSCALL_DEF(SYSCALL_SCHED_SLEEP, 11)
SYSCALL_DEF(SYSCALL_SCHED_SET_PRIORITY, 12)
SYSCALL_DEF(SYSCALL_SCHED_SET_AFFINITY, 13)
SYSCALL_DEF(SYSCALL_INTENT_SET, 14)
SYSCALL_DEF(SYSCALL_INTENT_GET, 15)
SYSCALL_DEF(SYSCALL_MEM_ALLOC_CLASS, 16)
SYSCALL_DEF(SYSCALL_FAULT_DOMAIN_CREATE, 17)
SYSCALL_DEF(SYSCALL_FAULT_DOMAIN_DESTROY, 18)
SYSCALL_DEF(SYSCALL_FAULT_DOMAIN_ATTACH, 19)

/* SDK compatibility syscalls (previously raw numbers) */
SYSCALL_DEF(SYSCALL_READ, 20)
SYSCALL_DEF(SYSCALL_WRITE, 21)
SYSCALL_DEF(SYSCALL_GET_SUBSYSTEM_CAPS, 22)

/* Thread exit for crt0/libc */
SYSCALL_DEF(SYSCALL_THREAD_EXIT, 23)
