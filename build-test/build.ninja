  LINK_FLAGS = -nostdlib   -z noexecstack -Xlinker --no-pie -Xlinker -m -Xlinker elf_x86_64 -nostdlib -Xlinker --fatal-warnings -Xlinker -T -Xlinker /app/kernel/linker.ld -Xlinker --build-id=none -Xlinker --no-dynamic-linker
  OBJECT_DIR = CMakeFiles/kernel.elf.dir
  POST_BUILD = :
  PRE_LINK = :
  TARGET_COMPILE_PDB = CMakeFiles/kernel.elf.dir/
  TARGET_FILE = kernel.elf
  TARGET_PDB = kernel.elf.pdb


#############################################
# Utility command for edit_cache

build CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = cd /app/build-test && /usr/bin/cmake -E echo No\ interactive\ CMake\ dialog\ available.
  DESC = No interactive CMake dialog available...
  restat = 1

build edit_cache: phony CMakeFiles/edit_cache.util


#############################################
# Utility command for rebuild_cache

build CMakeFiles/rebuild_cache.util: CUSTOM_COMMAND
  COMMAND = cd /app/build-test && /usr/bin/cmake --regenerate-during-build -S/app/kernel -B/app/build-test
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build rebuild_cache: phony CMakeFiles/rebuild_cache.util

