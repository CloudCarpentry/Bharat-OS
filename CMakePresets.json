{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "linux-host-debug",
      "displayName": "Linux Host (Debug)",
      "description": "Host build on Linux using Clang",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux-host-debug",
      "toolchainFile": "${sourceDir}/cmake/toolchains/host-linux-clang.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BHARAT_BUILD_HOST_TESTS": "ON",
        "BHARAT_DEVICE_PROFILE": "DESKTOP",
        "BHARAT_PERSONALITY_PROFILE": "LINUX"
      }
    },
    {
      "name": "linux-host-release",
      "displayName": "Linux Host (Release)",
      "description": "Host build on Linux using Clang",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux-host-release",
      "toolchainFile": "${sourceDir}/cmake/toolchains/host-linux-clang.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BHARAT_BUILD_HOST_TESTS": "ON",
        "BHARAT_DEVICE_PROFILE": "DESKTOP",
        "BHARAT_PERSONALITY_PROFILE": "LINUX"
      }
    },
    {
      "name": "linux-x86_64-dev-debug",
      "displayName": "Cross x86_64 Dev (Debug)",
      "description": "Cross-compile x86_64 target on Linux",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux-x86_64-dev-debug",
      "toolchainFile": "${sourceDir}/cmake/toolchains/x86_64-elf-clang.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BHARAT_DEVICE_PROFILE": "DESKTOP"
      }
    },
    {
      "name": "linux-arm64-edge-release",
      "displayName": "Cross ARM64 Edge (Release)",
      "description": "Cross-compile ARM64 Edge profile on Linux",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux-arm64-edge-release",
      "toolchainFile": "${sourceDir}/cmake/toolchains/aarch64-elf-clang.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BHARAT_DEVICE_PROFILE": "EDGE"
      }
    },
    {
      "name": "linux-riscv64-drone-release",
      "displayName": "Cross RISC-V Drone (Release)",
      "description": "Cross-compile RISC-V Drone profile on Linux",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux-riscv64-drone-release",
      "toolchainFile": "${sourceDir}/cmake/toolchains/riscv64-elf-clang.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BHARAT_DEVICE_PROFILE": "DRONE"
      }
    },
    {
      "name": "windows-hosttools-debug",
      "displayName": "Windows Host Tools (Debug)",
      "description": "Host tools build on Windows using Clang",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/windows-hosttools-debug",
      "toolchainFile": "${sourceDir}/cmake/toolchains/host-windows-clang.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BHARAT_BUILD_HOST_TESTS": "ON",
        "BHARAT_DEVICE_PROFILE": "DESKTOP",
        "BHARAT_PERSONALITY_PROFILE": "WINDOWS"
      }
    },
    {
      "name": "windows-sim-debug",
      "displayName": "Windows Simulation (Debug)",
      "description": "Subsystem simulation build on Windows",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/windows-sim-debug",
      "toolchainFile": "${sourceDir}/cmake/toolchains/host-windows-clang.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BHARAT_BUILD_HOST_TESTS": "ON",
        "BHARAT_DEVICE_PROFILE": "DESKTOP",
        "BHARAT_PERSONALITY_PROFILE": "WINDOWS"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-host-debug",
      "configurePreset": "linux-host-debug"
    },
    {
      "name": "linux-host-release",
      "configurePreset": "linux-host-release"
    },
    {
      "name": "linux-x86_64-dev-debug",
      "configurePreset": "linux-x86_64-dev-debug"
    },
    {
      "name": "linux-arm64-edge-release",
      "configurePreset": "linux-arm64-edge-release"
    },
    {
      "name": "linux-riscv64-drone-release",
      "configurePreset": "linux-riscv64-drone-release"
    },
    {
      "name": "windows-hosttools-debug",
      "configurePreset": "windows-hosttools-debug"
    },
    {
      "name": "windows-sim-debug",
      "configurePreset": "windows-sim-debug"
    }
  ],
  "testPresets": [
    {
      "name": "linux-host-debug",
      "configurePreset": "linux-host-debug",
      "output": {"outputOnFailure": true},
      "execution": {"noTestsAction": "error", "stopOnFailure": true}
    },
    {
      "name": "linux-host-release",
      "configurePreset": "linux-host-release",
      "output": {"outputOnFailure": true},
      "execution": {"noTestsAction": "error", "stopOnFailure": true}
    },
    {
      "name": "windows-hosttools-debug",
      "configurePreset": "windows-hosttools-debug",
      "output": {"outputOnFailure": true},
      "execution": {"noTestsAction": "error", "stopOnFailure": true}
    }
  ]
}
