SYSCALL_DEF(SYSCALL_VMM_UNMAP_PAGE, 5)
SYSCALL_DEF(SYSCALL_CAPABILITY_INVOKE, 6)
SYSCALL_DEF(SYSCALL_ENDPOINT_CREATE, 7)
SYSCALL_DEF(SYSCALL_ENDPOINT_SEND, 8)
SYSCALL_DEF(SYSCALL_ENDPOINT_RECEIVE, 9)
SYSCALL_DEF(SYSCALL_CAPABILITY_DELEGATE, 10)
SYSCALL_DEF(SYSCALL_SCHED_SLEEP, 11)
SYSCALL_DEF(SYSCALL_SCHED_SET_PRIORITY, 12)
SYSCALL_DEF(SYSCALL_SCHED_SET_AFFINITY, 13)
